task.spawn(function()
    while true do
        task.wait(math.random(120, 240)) -- Fires randomly every 2-4 minutes
        pcall(function()
            -- Micro camera movement to reset server-side idle checks
            local currentX, currentY = workspace.CurrentCamera.CFrame:ToEulerAnglesXYZ()
